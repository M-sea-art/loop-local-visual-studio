{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/M-sea-art/loop-local-visual-studio/visual/schemas/visual-spec.schema.json",
  "title": "LLVS visual fixture specification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "entry", "viewports"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "entry": { "type": "string", "minLength": 1 },
    "viewports": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "width", "height"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,31}$" },
          "width": { "type": "integer", "minimum": 240, "maximum": 7680 },
          "height": { "type": "integer", "minimum": 240, "maximum": 7680 }
        }
      }
    }
  }
}
