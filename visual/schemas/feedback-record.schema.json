{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/M-sea-art/loop-local-visual-studio/visual/schemas/feedback-record.schema.json",
  "title": "LLVS local feedback record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "createdAt", "sourceProject", "command", "summary", "detail", "errorCode", "status"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^LLVS-FEEDBACK-[a-f0-9]{32}$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "sourceProject": { "type": "string" },
    "command": { "type": "string" },
    "summary": { "type": "string" },
    "detail": { "type": "string" },
    "errorCode": { "type": "string", "pattern": "^[A-Z0-9_.-]{1,64}$" },
    "status": { "enum": ["NEW", "ACKNOWLEDGED", "RESOLVED", "REJECTED"] }
  }
}
